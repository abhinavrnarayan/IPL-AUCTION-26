NEXT_PUBLIC_APP_URL=http://localhost:10000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either legacy anon key or publishable default key (not both required).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Redis cache (optional but recommended) ─────────────────────────────────────
# Caches cricket API responses so monthly quotas are not burned on repeat fetches.
# Completed match scorecards are cached for 7 days; series/match lists for 30 min.
# Get a free database at https://redis.io/try-free/ or https://app.redislabs.com
REDIS_URL=

# ── Live Web Sync — Cricket API providers ─────────────────────────────────────
# At least one key is required to use the Live Web Sync feature.
# Free tier: 100 req/day — sign up at https://cricketdata.org
CRICKETDATA_API_KEY=

# RapidAPI Cricbuzz — sign up at https://rapidapi.com/cricketapilive/api/cricbuzz-cricket
RAPIDAPI_KEY=
# Optional second RapidAPI key — used automatically if the primary key hits its quota (429/402)
RAPIDAPI_KEY_2=
# Optional: override host if you subscribe to a different Cricbuzz plan
# RAPIDAPI_CRICBUZZ_HOST=cricbuzz-cricket.p.rapidapi.com

# AllThingsDev Cricbuzz — sign up at https://allthingsdev.co
# Used as Tier 3 fallback. Set ATD_API_ENDPOINT if your plan requires per-endpoint UUIDs.
ATD_API_KEY=
# ATD_API_ENDPOINT=
